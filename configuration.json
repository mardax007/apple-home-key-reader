{
    "logging": {
        "level": 20
    },

    "nfc": {
        "path": "tty:usbserial-0001:pn532",
        "broadcast": true,
        "known_uids_file": "known_nfc_uids.json",
        "new_uids_file": "new_nfc_uid.json",
        "access_log_file": "access_log.jsonl",
        "on_known_shell_command": "",
        "on_unknown_shell_command": ""
    },

    "hap": {
        "port": 51926,
        "persist": "hap.state",
        "default": "locked"
    },

    "homekey": {
        "persist": "homekey.json",
        "express": true,
        "finish": "silver",
        "flow": "fast",
        "user_names_file": "homekey_user_names.json"
    }
}
