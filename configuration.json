{
    "logging": {
        "level": 20
    },

    "nfc": {
        "path": "tty:usbserial-0001:pn532",
        "broadcast": true,
        "known_uids_file": "known_nfc_uids.json",
        "new_uids_file": "new_nfc_uids.json",
        "access_log_file": "access_log.jsonl",
        "on_unlock_shell_command": "",
        "on_known_shell_command": "",
        "on_unknown_shell_command": ""
    },

    "hap": {
        "port": 51926,
        "persist": "hap.state",
        "default": "locked"
    },

    "homekey": {
        "persist": "homekey.json",
        "express": true,
        "finish": "silver",
        "flow": "fast",
        "user_names_file": "homekey_user_names.json",
        "home_assistant": {
            "enabled": true,
            "host": "0.0.0.0",
            "port": 9780,
            "token": "",
            "enable_shell_command": true,
            "shell_command_whitelist": []
        }
    }
}
